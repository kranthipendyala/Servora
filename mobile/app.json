{
  "expo": {
    "name": "Servora",
    "slug": "servora",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "servora",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "cover",
      "backgroundColor": "#145224"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.servora.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#145224"
      },
      "package": "com.servora.app"
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": ["expo-router", "expo-font"],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": { "origin": false }
    }
  }
}
